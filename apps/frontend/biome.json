{
	"$schema": "https://biomejs.dev/schemas/2.3.10/schema.json",
	"root": false,
	"extends": "//",
	"files": {
		"includes": ["!**/node_modules", "!**/dist", "!**/test-results", "!**/playwright-report"]
	},
	"linter": {
		"rules": {
			"a11y": {
				"useMediaCaption": "error",
				"useKeyWithClickEvents": "error",
				"noSvgWithoutTitle": "error",
				"noStaticElementInteractions": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/features/editor/**", "src/components/**", "src/lib/**", "src/hooks/**"],
			"linter": {
				"rules": {
					"a11y": {
						"useMediaCaption": "off",
						"useKeyWithClickEvents": "off",
						"noSvgWithoutTitle": "off",
						"noStaticElementInteractions": "off"
					},
					"complexity": {
						"noBannedTypes": "off",
						"noForEach": "off"
					},
					"correctness": {
						"noUnsafeOptionalChaining": "off",
						"useExhaustiveDependencies": "off",
						"noUnusedVariables": "off",
						"noUnusedFunctionParameters": "off"
					},
					"performance": {
						"noAccumulatingSpread": "off"
					},
					"security": {
						"noDangerouslySetInnerHtml": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					},
					"suspicious": {
						"noExplicitAny": "off",
						"noArrayIndexKey": "off",
						"noAssignInExpressions": "off",
						"noImplicitAnyLet": "off",
						"noNonNullAssertedOptionalChain": "off"
					}
				}
			}
		},
		{
			"includes": ["src/features/editor/scene/droppable.tsx"],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off"
					}
				}
			}
		},
		{
			"includes": ["src/features/editor/timeline/timeline.tsx"],
			"linter": {
				"rules": {
					"a11y": {
						"useKeyWithMouseEvents": "off"
					}
				}
			}
		}
	]
}
