{
	"$schema": "https://biomejs.dev/schemas/2.3.10/schema.json",
	"root": false,
	"extends": "//",
	"linter": {
		"rules": {
			"style": {
				"useNodejsImportProtocol": "error"
			},
			"performance": {
				"noBarrelFile": "off",
				"noReExportAll": "off"
			},
			"suspicious": {
				"noConsole": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/config/env.ts"],
			"linter": {
				"rules": {
					"style": {
						"useNamingConvention": "off"
					}
				}
			}
		}
	]
}
