NODE_TLS_REJECT_UNAUTHORIZED=0

# Server
PORT=4001
HOST=127.0.0.1
SERVER_BASE_URL=http://localhost:4001

# FFmpeg
FFMPEG_PRESET=veryfast
FFMPEG_CRF=20
FFMPEG_AUDIO_BITRATE=192k
FFMPEG_MAX_CONCURRENT=2
MIN_TRANSCODE_SEGMENT_SECONDS=0.35
# FFMPEG_FONT_PATH=/path/to/font.ttf

# Preview (MPD → HLS)
# CORE_BASE_URL points at the Core service (mocked locally by apps/core-mock).
# The /private prefix is intentional — real Core groups auth-required endpoints there.
CORE_BASE_URL=http://localhost:8002/private
MOCK_VOD_BASE_URL=http://localhost:5050
MAX_PREVIEW_DURATION_MS=3600000
PREVIEW_JOB_TTL_SECONDS=86400
S3_PREVIEW_PREFIX=preview
PREVIEW_SIGNING_SECRET=dev-only-not-secret-change-in-production-32chars

# MPD
ENABLE_MPD_RESTRICTIONS=false
TRANSCODE_TIMEOUT_MS=7200000
MAX_TEMP_FILE_SIZE_MB=5000
MPD_TRANSCODE_CRF_MULTI=10
MPD_TRANSCODE_CRF_SINGLE=18
MPD_TRANSCODE_PRESET=medium

# S3 (MinIO defaults for local dev)
S3_BUCKET=react-video-editor
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_UPLOAD_PREFIX=uploads
S3_OUTPUT_PREFIX=output
S3_AUTO_CREATE_BUCKET=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
JOB_PROGRESS_TTL_SECONDS=600

# Render
RENDER_URL_EXPIRY_SECONDS=86400

# Messaging
RABBITMQ_URL=amqp://guest:guest@localhost:5672