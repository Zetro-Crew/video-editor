{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"root": true,
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!**/node_modules",
			"!**/dist",
			"!**/build",
			"!**/coverage",
			"!**/*.tsbuildinfo"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error",
				"noUnusedFunctionParameters": "error",
				"useExhaustiveDependencies": "warn"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noArrayIndexKey": "error",
				"noImplicitAnyLet": "error",
				"noConsole": {
					"level": "warn",
					"options": {
						"allow": ["error", "warn"]
					}
				}
			},
			"style": {
				"useImportType": "error",
				"useExportType": "error",
				"useConst": "error",
				"useTemplate": "error",
				"noParameterAssign": "error",
				"noUselessElse": "error",
				"noNonNullAssertion": "error"
			},
			"security": {
				"noDangerouslySetInnerHtml": "error"
			},
			"performance": {
				"noAccumulatingSpread": "error",
				"noBarrelFile": "error",
				"noReExportAll": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.css"],
			"linter": {
				"rules": {
					"style": {
						"noDescendingSpecificity": "off"
					}
				}
			}
		},
		{
			"includes": [
				"**/*.test.*",
				"**/*.spec.*",
				"**/__tests__/**",
				"**/test/**"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					},
					"correctness": {
						"noUnusedFunctionParameters": "off"
					}
				}
			}
		},
		{
			"includes": ["**/scripts/**", "**/*.config.*"],
			"linter": {
				"rules": {
					"performance": {
						"noBarrelFile": "off"
					},
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		},
		{
			"includes": ["packages/*/src/index.ts", "packages/*/src/*/index.ts"],
			"linter": {
				"rules": {
					"performance": {
						"noBarrelFile": "off",
						"noReExportAll": "off"
					}
				}
			}
		}
	]
}
